# ============================================
# AI Work OS - Backend Environment Variables
# ============================================

# Application
APP_NAME=AI Work OS
ENVIRONMENT=development
DEBUG=true

# LLM Provider (openai | dashscope)
LLM_PROVIDER=dashscope

# OpenAI Configuration (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=4000

# Alibaba Cloud Bailian (DashScope) Configuration (used when LLM_PROVIDER=dashscope)
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_TEMPERATURE=0.3
DASHSCOPE_MAX_TOKENS=4000

# Database (PostgreSQL) - Note: Using port 5433 to avoid conflicts
DATABASE_URL=postgresql+asyncpg://admin:aiworkos_secret_2026@localhost:5433/ai_work_os
DATABASE_URL_SYNC=postgresql://admin:aiworkos_secret_2026@localhost:5433/ai_work_os

# Redis - Note: Using port 6380 to avoid conflicts
REDIS_URL=redis://localhost:6380/0

# JWT Authentication
JWT_SECRET=aiworkos-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (comma-separated list)
ALLOWED_ORIGINS="http://localhost:3001,http://127.0.0.1:3001"
