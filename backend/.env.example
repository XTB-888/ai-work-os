# ============================================
# AI Work OS - Backend Environment Variables
# ============================================

# Application
APP_NAME=AI Work OS
ENVIRONMENT=development
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://admin:aiworkos_secret_2026@localhost:5432/ai_work_os
DATABASE_URL_SYNC=postgresql://admin:aiworkos_secret_2026@localhost:5432/ai_work_os

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET=aiworkos-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=4000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
